{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "accessgreendesigngroup",
  "compatibility_date": "2026-04-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": ["node_modules", "scripts", "images-src", "package.json", "package-lock.json"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
